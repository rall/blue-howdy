#!/bin/bash
# Re-enable Howdy face auth after a user session is active and unlocked.
# Works for both post-boot (new session) and post-resume (session unlock).
# Launched by howdy-suspend-hook or howdy-boot-reenable.service.

HOWDY_CONFIG="/etc/howdy/config.ini"

[ -f "$HOWDY_CONFIG" ] || exit 0
grep -q '^disabled = true' "$HOWDY_CONFIG" || exit 0

reenable() {
    sed -i '/^disabled = true$/d' "$HOWDY_CONFIG" 2>/dev/null
}

# Check if any non-greeter user session is active and unlocked.
user_session_unlocked() {
    local session stype locked active
    for session in $(loginctl list-sessions --no-legend 2>/dev/null | awk '{print $1}'); do
        stype=$(loginctl show-session "$session" -p Type --value 2>/dev/null)
        active=$(loginctl show-session "$session" -p Active --value 2>/dev/null)
        locked=$(loginctl show-session "$session" -p LockedHint --value 2>/dev/null)
        if [[ "$stype" == "user" && "$active" == "yes" && "$locked" == "no" ]]; then
            return 0
        fi
    done
    return 1
}

if command -v gdbus > /dev/null 2>&1; then
    coproc GDBUS { timeout 300 gdbus monitor --system --dest org.freedesktop.login1 2>/dev/null; }
    trap "kill $GDBUS_PID 2>/dev/null" EXIT

    while IFS= read -r line <&"${GDBUS[0]}"; do
        # React to session unlock (resume) or new session creation (boot)
        if [[ "$line" == *"'LockedHint': <false>"* ]] || [[ "$line" == *"SessionNew"* ]]; then
            sleep 1
            if user_session_unlocked; then
                break
            fi
        fi
    done
else
    sleep 60
fi

reenable
