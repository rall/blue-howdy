#!/bin/bash
# Create a marker file when the system is about to suspend.
# howdy-session-gate reads this to skip Howdy on the lock screen after resume,
# forcing password authentication so gnome-keyring can unlock properly.
if [ "$1" = "pre" ]; then
    touch /run/howdy-suspended
    # Ensure correct SELinux label (var_run_t) so the session gate
    # (running as xdm_t under GDM) can read and remove the marker.
    restorecon /run/howdy-suspended 2>/dev/null || true
fi
