#!/bin/bash
# Temporarily disable Howdy face auth before suspend.
#
# After resume, pam_howdy sees disabled=true and returns PAM_AUTH_ERR.
# Because pam_howdy is configured as "sufficient", this failure simply
# continues to the next PAM module — GDM shows its normal password prompt
# and gnome-keyring gets the password it needs to unlock.
#
# howdy-reenable listens for the session unlock signal via D-Bus and
# re-enables Howdy immediately once the user has authenticated.

HOWDY_CONFIG="/etc/howdy/config.ini"

if [ "$1" = "pre" ]; then
    # Kill any lingering listener (and its gdbus child) from a previous resume
    # before systemd tries to freeze user.slice — unfrozen processes block suspend
    pkill -f howdy-reenable 2>/dev/null || true
    pkill -f 'gdbus monitor.*login1' 2>/dev/null || true
    [ -f "$HOWDY_CONFIG" ] || exit 0
    if grep -q '^disabled' "$HOWDY_CONFIG"; then
        sed -i 's/^disabled.*/disabled = true/' "$HOWDY_CONFIG"
    else
        sed -i '/^\[core\]/a disabled = true' "$HOWDY_CONFIG"
    fi
fi

if [ "$1" = "post" ]; then
    [ -f "$HOWDY_CONFIG" ] || exit 0
    grep -q '^disabled = true' "$HOWDY_CONFIG" || exit 0
    /usr/libexec/howdy-reenable &
fi
