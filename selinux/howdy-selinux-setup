#!/usr/bin/env bash
set -euo pipefail

WRK="/run/howdy"

log(){ logger -t "howdy-selinux-setup" -- "$*"; }

# Resolve semodule path (prefer absolute), bail quietly if missing
SEM="/usr/sbin/semodule"
[ -x "$SEM" ] || SEM="$(command -v semodule || true)"
if [ -z "${SEM:-}" ]; then
  log "semodule not found; is policycoreutils installed? skipping"
  exit 0
fi

# Only act on SELinux-enabled systems
if ! sestatus >/dev/null 2>&1 || ! sestatus 2>/dev/null | grep -q 'enabled'; then
  exit 0
fi

# Check if already installed.  Newer semodule -l may omit version numbers,
# so also compare the .te source to detect content changes.
INSTALLED=$("$SEM" -l 2>/dev/null | grep -q '^howdy_dm' && echo yes || echo no)
if [ "$INSTALLED" = "yes" ] && \
   cmp -s /usr/share/selinux/howdy/howdy_dm.te "$WRK/howdy_dm.te.prev" 2>/dev/null; then
  exit 0
fi
if [ "$INSTALLED" = "yes" ]; then
  log "reinstalling howdy_dm (policy source changed)"
fi

install -d -m0755 "$WRK"
cp -f "/usr/share/selinux/howdy/howdy_dm.te" "$WRK/"
cp -f "/usr/share/selinux/howdy/howdy_dm.fc" "$WRK/" 2>/dev/null || true

# Prefer devel Makefile; else fall back to raw toolchain (module ver 21)
if [ -f /usr/share/selinux/devel/Makefile ]; then
  log "building via devel Makefile"
  make -s -f /usr/share/selinux/devel/Makefile -C "$WRK" howdy_dm.pp
else
  log "building via checkmodule/semodule_package (c=21)"
  checkmodule -M -m -c 21 -o "$WRK/howdy_dm.mod" "$WRK/howdy_dm.te"
  FC_OPT=""
  [ -f "$WRK/howdy_dm.fc" ] && FC_OPT="-f $WRK/howdy_dm.fc"
  semodule_package -o "$WRK/howdy_dm.pp" -m "$WRK/howdy_dm.mod" $FC_OPT
fi

# Try to install the compiled module — log errors so failures are visible
if output=$("$SEM" -i "$WRK/howdy_dm.pp" 2>&1); then
  log "installed TE module"
  # Cache the .te source so we can detect future content changes
  cp -f "$WRK/howdy_dm.te" "$WRK/howdy_dm.te.prev"
  # Remove stale audit2allow fallback module if present
  "$SEM" -r howdy_gdm_auto 2>/dev/null && log "removed stale howdy_gdm_auto module" || true
  exit 0
else
  log "semodule -i failed: $output"
fi

# Optional: AVC-derived module
if command -v ausearch >/dev/null && command -v audit2allow >/dev/null; then
  (ausearch -m avc -ts boot || ausearch -m avc -ts recent) > "$WRK/howdy.avc" || true
  if [ -s "$WRK/howdy.avc" ]; then
    log "installing AVC-derived module"
    audit2allow -M howdy_dm_auto -i "$WRK/howdy.avc" && "$SEM" -X 400 -i howdy_dm_auto.pp || true
  fi
fi

exit 0
